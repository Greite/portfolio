{
  "name": "portfolio",
  "version": "4.8.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prestart": "cp -R .next/static/ .next/standalone/.next/static/ && cp -R public/ .next/standalone/public/",
    "start": "node .next/standalone/server.js",
    "prod": "bun run build && bun start",
    "prelint": "next typegen",
    "lint": "bun tsc && bun biome:check && bun biome:format",
    "tsc": "tsc --noEmit",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "biome:format:write": "biome format --write .",
    "biome:format": "biome format .",
    "biome:write": "biome check --write . && biome format --write ."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "next": "^16.2.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-icons": "^5.7.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
