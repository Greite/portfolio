{
  "name": "portfolio",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prestart": "cp -R .next/static/ .next/standalone/.next/static/ && cp -R public/ .next/standalone/public/",
    "start": "node .next/standalone/server.js",
    "prod": "pnpm build && pnpm start",
    "prelint": "next typegen",
    "lint": "pnpm tsc && pnpm biome:check && pnpm biome:format",
    "tsc": "tsc --noEmit",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "biome:format:write": "biome format --write .",
    "biome:format": "biome format .",
    "biome:write": "biome check --write . && biome format --write ."
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^6.0.3"
  }
}
