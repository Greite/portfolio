{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/.pnpm-store",
      "!**/out",
      "!**/build",
      "!**/public",
      "!**/.claude",
      "!**/.vscode",
      "!**/.playwright-mcp",
      "!**/*.tsbuildinfo",
      "!**/*.pen",
      "!next-env.d.ts",
      "!pnpm-lock.yaml",
      "!CLAUDE.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSpacing": true,
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "error",
        "noNonNullAssertion": "off",
        "noParameterAssign": "error",
        "noNestedTernary": "warn",
        "useTemplate": "error",
        "useDefaultParameterLast": "error",
        "noUselessElse": "warn",
        "useShorthandAssign": "error",
        "useBlockStatements": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noArrayIndexKey": "off",
        "noImplicitAnyLet": "error",
        "noShadowRestrictedNames": "error",
        "useIterableCallbackReturn": "error",
        "noConsole": "warn",
        "noDuplicateElseIf": "error"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "error",
        "useJsxKeyInIterable": "error",
        "noUndeclaredDependencies": "off"
      },
      "a11y": {
        "recommended": true,
        "noSvgWithoutTitle": "warn",
        "noStaticElementInteractions": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["*.d.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    },
    {
      "includes": ["components/ThemeToggle.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":BUN:", ":NODE:"],
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ":PATH:",
              ":BLANK_LINE:",
              ["@components/**", "@public/**", "@root/**"]
            ]
          }
        }
      }
    }
  }
}
